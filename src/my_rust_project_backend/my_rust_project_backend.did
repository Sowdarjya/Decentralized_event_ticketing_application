type User = record {
  id: principal;
  name: text;
  email: text;
  tickets_purchased: nat64;
  is_organizer: bool;
  created_at: nat64;
};

type CreateUserResult = variant {
  Ok: User;
  Err: text;
};

service : {
  greet: (text) -> (text) query;
  create_user: (text, text, bool) -> (CreateUserResult);
}